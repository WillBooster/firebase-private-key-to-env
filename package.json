{
  "name": "firebase-private-key-to-env",
  "version": "1.0.0",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/WillBooster/firebase-private-key-to-env.git"
  },
  "license": "Apache-2.0",
  "author": "WillBooster Inc.",
  "type": "module",
  "main": "src/index.ts",
  "scripts": {
    "cleanup": "yarn format && yarn lint-fix",
    "format": "sort-package-json && yarn format-code",
    "format-code": "oxfmt --write --no-error-on-unmatched-pattern . '!**/package.json'",
    "lint": "oxlint --type-aware --type-check --no-error-on-unmatched-pattern .",
    "lint-fix": "yarn lint --fix",
    "prepare": "lefthook install || true",
    "start": "babel-node -x .js,.jsx,.es6,.es,.ts src/index.ts",
    "test": "echo \"No tests configured\"",
    "typecheck": "wb typecheck",
    "verify": "wb verify",
    "verify-full": "wb verify --full"
  },
  "dependencies": {
    "core-js": "3.49.0",
    "yargs": "18.0.0"
  },
  "devDependencies": {
    "@babel/cli": "7.29.7",
    "@babel/core": "7.29.7",
    "@babel/node": "7.29.7",
    "@babel/plugin-proposal-class-properties": "7.18.6",
    "@babel/plugin-proposal-numeric-separator": "7.18.6",
    "@babel/preset-env": "7.29.7",
    "@babel/preset-typescript": "7.29.7",
    "@tsconfig/node-lts": "24.0.0",
    "@tsconfig/node-ts": "23.6.4",
    "@types/node": "24.13.2",
    "@types/yargs": "17.0.35",
    "@willbooster/oxfmt-config": "1.2.2",
    "@willbooster/oxlint-config": "1.4.8",
    "@willbooster/wb": "13.26.2",
    "lefthook": "2.1.10",
    "oxfmt": "0.58.0",
    "oxlint": "1.73.0",
    "oxlint-tsgolint": "0.24.0",
    "sort-package-json": "4.0.0",
    "typescript": "7.0.2"
  },
  "packageManager": "yarn@4.17.1",
  "publishConfig": {
    "access": "public"
  }
}
