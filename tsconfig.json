{
  "compilerOptions": {
    "allowSyntheticDefaultImports": true,
    "alwaysStrict": true,
    "declaration": true,
    "erasableSyntaxOnly": true,
    "esModuleInterop": true,
    "importHelpers": false,
    "noEmit": true,
    "noUncheckedIndexedAccess": true,
    "outDir": "dist",
    "paths": {
      "undici-types": ["./node_modules/undici-types/index.d.ts"]
    },
    "resolveJsonModule": true,
    "rootDir": ".",
    "skipLibCheck": true,
    "sourceMap": true,
    "strict": true,
    "target": "ESNext",
    "typeRoots": ["./node_modules/@types", "./@types"],
    "types": ["node", "bun"]
  },
  "exclude": ["test/fixtures"],
  "extends": ["@tsconfig/bun/tsconfig.json", "@tsconfig/node-lts/tsconfig.json", "@tsconfig/node-ts/tsconfig.json"],
  "include": ["*.config.ts", "scripts/**/*", "src/**/*", "test/**/*"]
}
